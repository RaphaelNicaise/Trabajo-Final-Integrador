FROM node:20-alpine

RUN npm install -g pnpm

WORKDIR /app

COPY frontend/package.json frontend/pnpm-lock.yaml* frontend/.npmrc* ./

RUN pnpm install

COPY frontend/ .

ENV NODE_OPTIONS="--max-old-space-size=2048"
ENV WATCHPACK_POLLING=true

EXPOSE 3000

CMD ["pnpm", "dev", "--hostname", "0.0.0.0", "--port", "3000"]